mixin mapSection(points)
  -
    const mapPoints = points || []
    const mapPointsJson = JSON.stringify(mapPoints)

  section.infrastructure-map#location
    .infrastructure-map__inner.container
      h2.infrastructure-map__title Инфраструктура
      .infrastructure-map__map.js-yandex-map(data-points=mapPointsJson)
      ul.infrastructure-map__legend
        each point in mapPoints
          li.infrastructure-map__legend-item
            img.infrastructure-map__legend-icon(src=point.legendIcon alt="" loading="lazy")
            span.infrastructure-map__legend-text= point.category
