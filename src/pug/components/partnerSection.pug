mixin partnerSection(items)
  section.partner#developer
    .partner__inner.container
      .partner__content
        h2.partner__title Город Новостроек - официальный партнёр НСИ-Юг
        p.partner__text Мы хорошо знаем проекты застройщика, особенности планировок и реальную логику выбора: где удобнее для семьи, а где выгоднее условия покупки.
        +button({ text: 'Подобрать квартиру в ЖК НСИ-Юг', theme: 'green', href: '#contacts', className: 'partner__button' })
      .partner__facts
        each item in items
          article.partner__fact
            span.partner__fact-icon
            h3.partner__fact-title= item.number
            p.partner__fact-text= item.label
